import { useParams, useNavigate } from "react-router-dom"
import { useEffect, useState } from "react"
import api from "../../services/api"

function ClassDetails() {
  const { classId } = useParams()
  const navigate = useNavigate()

  const [students, setStudents] = useState([])
  const [loading, setLoading] = useState(true)
  const [showMenu, setShowMenu] = useState(null)

  useEffect(() => {
    if (!classId) return

    api
      .get(`/admin/classes/${classId}/students`)
      .then(res => setStudents(res.data))
      .catch(err =>
        console.error(
          "Students API error:",
          err.response?.data || err.message
        )
      )
      .finally(() => setLoading(false))
  }, [classId])

  const activeStudents = students.filter(
    s => s.academicStatus !== "archived" &&
         s.academicStatus !== "expelled" &&
         s.academicStatus !== "transferred"
  )

  // Handler functions
  const toggleMenu = (studentId) => {
    setShowMenu(showMenu === studentId ? null : studentId)
  }

  const handleViewStudent = (student) => {
    console.log("View student:", student)
    setShowMenu(null)
    // Navigate to student profile or show modal
    alert(`Viewing student: ${student.name}`)
  }

  const handleEditStudent = (student) => {
    console.log("Edit student:", student)
    setShowMenu(null)
    // Navigate to edit student page
    alert(`Editing student: ${student.name}`)
  }

  const handleViewAttendance = (student) => {
    console.log("View attendance:", student)
    setShowMenu(null)
    // Navigate to attendance page
    alert(`Viewing attendance for: ${student.name}`)
  }

  const handleViewFees = (student) => {
    console.log("View fees:", student)
    setShowMenu(null)
    // Navigate to fees page
    alert(`Viewing fees for: ${student.name}`)
  }

  const handleViewResults = (student) => {
    console.log("View results:", student)
    setShowMenu(null)
    // Navigate to results page
    alert(`Viewing results for: ${student.name}`)
  }

  const handleViewDocuments = (student) => {
    console.log("View documents:", student)
    setShowMenu(null)
    // Navigate to documents page
    alert(`Viewing documents for: ${student.name}`)
  }

  const handleExpelStudent = (student) => {
    if (confirm(`Are you sure you want to expel ${student.name}?`)) {
      console.log("Expel student:", student)
      setShowMenu(null)
      // Call API to expel student
      alert(`Expelled student: ${student.name}`)
    }
  }

  return (
    <div className="min-h-screen bg-black p-6 space-y-6">

      {/* HEADER */}
      <div className="bg-gray-900 rounded-2xl shadow-lg p-6 border border-gray-800">
        <div className="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
          <div>
            <h1 className="text-4xl font-bold text-white">
              Class Students
            </h1>
            <p className="text-gray-400 mt-2 text-lg">
              Manage students enrolled in this class
            </p>
          </div>

          <button
            onClick={() =>
              navigate(`/admin/classes/${classId}/add-student`)
          }
          className="px-8 py-3 bg-gray-800 text-white rounded-xl hover:bg-gray-700 transition-all duration-200 font-medium border border-gray-700"
        >
          + Add Student
        </button>
      </div>

      {/* STATS BAR */}
      <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
        <StatCard label="Total Students" value={students.length} />
        <StatCard label="Active" value={activeStudents.length} />
        <StatCard label="Boys" value={students.filter(s => s.gender === "Male").length} />
        <StatCard label="Girls" value={students.filter(s => s.gender === "Female").length} />
      </div>

      {/* TABLE */}
      {loading ? (
        <Skeleton />
      ) : students.length === 0 ? (
        <EmptyState onAdd={() => navigate(`/admin/classes/${classId}/add-student`)} />
      ) : (
        <div className="bg-gray-900 rounded-2xl shadow-xl overflow-x-auto border border-gray-800">
          <table className="w-full">
            <thead className="bg-gray-800 text-sm">
              <tr>
                <th className="p-4 text-left font-semibold text-gray-300">Roll No</th>
                <th className="p-4 text-left font-semibold text-gray-300">Student</th>
                <th className="p-4 text-left font-semibold text-gray-300">Gender</th>
                <th className="p-4 text-left font-semibold text-gray-300">Parent</th>
                <th className="p-4 text-left font-semibold text-gray-300">Phone</th>
                <th className="p-4 text-left font-semibold text-gray-300">Status</th>
                <th className="p-4 text-left font-semibold text-gray-300">Actions</th>
              </tr>
            </thead>

            <tbody>
              {students.map(s => (
                <tr
                  key={s._id}
                  className="border-t border-gray-800 hover:bg-gray-800 transition-all duration-200"
                >
                  <td className="p-4">
                    <span className="inline-flex items-center justify-center w-8 h-8 bg-gray-800 text-gray-300 rounded-lg font-mono text-sm font-semibold">
                      {s.rollNo || "—"}
                    </span>
                  </td>

                  <td className="p-4">
                    <div className="flex items-center space-x-3">
                      <div className="w-10 h-10 bg-gray-700 rounded-full flex items-center justify-center text-white font-bold">
                        {s.name?.charAt(0)?.toUpperCase()}
                      </div>
                      <div>
                        <p className="font-semibold text-white">{s.name}</p>
                        <p className="text-xs text-gray-400">
                          Admission: {s.admissionNo || "—"}
                        </p>
                      </div>
                    </div>
                  </td>

                  <td className="p-4">
                    <span className={`inline-flex items-center px-3 py-1 rounded-full text-xs font-medium ${
                      s.gender === "Male" 
                        ? "bg-blue-900 text-blue-300" 
                        : s.gender === "Female"
                        ? "bg-pink-900 text-pink-300"
                        : "bg-gray-700 text-gray-300"
                    }`}>
                      {s.gender === "Male" && "👦 "}
                      {s.gender === "Female" && "👧 "}
                      {s.gender || "—"}
                    </span>
                  </td>

                  <td className="p-4">
                    <div className="flex items-center space-x-2">
                      <div className="w-8 h-8 bg-gray-700 rounded-full flex items-center justify-center text-white text-xs">
                        👤
                      </div>
                      <span className="font-medium text-gray-300">{s.parentName || "—"}</span>
                    </div>
                  </td>

                  <td className="p-4">
                    {s.parentPhone ? (
                      <div className="flex items-center space-x-2">
                        <div className="w-8 h-8 bg-gray-700 rounded-full flex items-center justify-center text-white text-xs">
                          📞
                        </div>
                        <span className="font-mono text-sm text-gray-300">
                          {s.parentPhone.slice(0, 5)}-{s.parentPhone.slice(5)}
                        </span>
                      </div>
                    ) : (
                      <span className="text-gray-500">—</span>
                    )}
                  </td>

                  <td className="p-4">
                    <span
                      className={`inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold
                        ${
                          s.academicStatus === "active"
                            ? "bg-green-900 text-green-300"
                            : s.academicStatus === "archived"
                            ? "bg-yellow-900 text-yellow-300"
                            : s.academicStatus === "expelled"
                            ? "bg-red-900 text-red-300"
                            : s.academicStatus === "transferred"
                            ? "bg-blue-900 text-blue-300"
                            : "bg-gray-700 text-gray-300"
                        }
                      `}
                    >
                      {s.academicStatus === "active" && "✅ "}
                      {s.academicStatus === "archived" && "📦 "}
                      {s.academicStatus === "expelled" && "❌ "}
                      {s.academicStatus === "transferred" && "🔄 "}
                      {s.academicStatus || "active"}
                    </span>
                  </td>

                  <td className="p-4">
                    <div className="flex items-center space-x-2">
                      {/* Eye Button */}
                      <button
                        onClick={() => handleViewStudent(s)}
                        className="w-8 h-8 bg-gray-700 hover:bg-gray-600 rounded-lg flex items-center justify-center text-white transition-colors duration-200"
                        title="View Student"
                      >
                        👁️
                      </button>
                      
                      {/* Three Dots Menu */}
                      <div className="relative">
                        <button
                          onClick={() => toggleMenu(s._id)}
                          className="w-8 h-8 bg-gray-700 hover:bg-gray-600 rounded-lg flex items-center justify-center text-white transition-colors duration-200"
                          title="More Options"
                        >
                          ⋯
                        </button>
                        
                        {/* Dropdown Menu */}
                        {showMenu === s._id && (
                          <div className="absolute right-0 mt-2 w-48 bg-gray-800 border border-gray-700 rounded-lg shadow-xl z-10">
                            <button
                              onClick={() => handleEditStudent(s)}
                              className="w-full text-left px-4 py-2 text-gray-300 hover:bg-gray-700 transition-colors duration-200"
                            >
                              ✏️ Edit Student
                            </button>
                            <button
                              onClick={() => handleViewAttendance(s)}
                              className="w-full text-left px-4 py-2 text-gray-300 hover:bg-gray-700 transition-colors duration-200"
                            >
                              📊 View Attendance
                            </button>
                            <button
                              onClick={() => handleViewFees(s)}
                              className="w-full text-left px-4 py-2 text-gray-300 hover:bg-gray-700 transition-colors duration-200"
                            >
                              💰 View Fees
                            </button>
                            <button
                              onClick={() => handleViewResults(s)}
                              className="w-full text-left px-4 py-2 text-gray-300 hover:bg-gray-700 transition-colors duration-200"
                            >
                              📝 View Results
                            </button>
                            <button
                              onClick={() => handleViewDocuments(s)}
                              className="w-full text-left px-4 py-2 text-gray-300 hover:bg-gray-700 transition-colors duration-200"
                            >
                              📁 View Documents
                            </button>
                            <hr className="border-gray-700" />
                            <button
                              onClick={() => handleExpelStudent(s)}
                              className="w-full text-left px-4 py-2 text-red-400 hover:bg-red-900/20 transition-colors duration-200"
                            >
                              ❌ Expel Student
                            </button>
                          </div>
                        )}
                      </div>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  )
}

/* ================= COMPONENTS ================= */

function StatCard({ label, value }) {
  const getCardColors = (label) => {
    if (label.includes("Total")) return "from-purple-600 to-purple-800";
    if (label.includes("Active")) return "from-green-600 to-green-800";
    if (label.includes("Boys")) return "from-blue-600 to-blue-800";
    if (label.includes("Girls")) return "from-pink-600 to-pink-800";
    return "from-gray-600 to-gray-800";
  };

  return (
    <div className="bg-gray-900 rounded-2xl p-6 shadow-lg border border-gray-800 hover:shadow-xl transition-all duration-200">
      <div className={`w-12 h-12 bg-gradient-to-r ${getCardColors(label)} rounded-lg flex items-center justify-center mb-4`}>
        <span className="text-white text-xl font-bold">
          {label.includes("Total") && "👥"}
          {label.includes("Active") && "✅"}
          {label.includes("Boys") && "👦"}
          {label.includes("Girls") && "👧"}
        </span>
      </div>
      <p className="text-sm text-gray-400 font-medium">{label}</p>
      <p className="text-3xl font-bold mt-2 text-white">{value}</p>
    </div>
  )
}

function EmptyState({ onAdd }) {
  return (
    <div className="bg-gray-900 rounded-3xl p-16 text-center shadow-xl border border-gray-800">
      <div className="w-24 h-24 bg-gray-800 rounded-full flex items-center justify-center mx-auto mb-6">
        <span className="text-gray-400 text-4xl">🎓</span>
      </div>
      <h2 className="text-2xl font-bold text-white mb-3">
        No students found
      </h2>
      <p className="text-gray-400 mb-8 text-lg">
        Start by adding students to this class
      </p>
      <button
        onClick={onAdd}
        className="px-8 py-3 bg-gray-800 text-white rounded-xl hover:bg-gray-700 transition-all duration-200 font-medium border border-gray-700"
      >
        + Add First Student
      </button>
    </div>
  )
}

function Skeleton() {
  return (
    <div className="bg-gray-900 rounded-2xl p-8 shadow-xl border border-gray-800 animate-pulse">
      <div className="h-6 bg-gray-800 rounded w-1/3 mb-6" />
      <div className="space-y-4">
        <div className="h-4 bg-gray-800 rounded" />
        <div className="h-4 bg-gray-800 rounded w-5/6" />
        <div className="h-4 bg-gray-800 rounded w-4/6" />
        <div className="h-4 bg-gray-800 rounded w-3/4" />
      </div>
    </div>
  )
}

export default ClassDetails
